# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is git-ignored.

# Public base URL used for Open Graph tags, canonical URLs, and sitemap/robots.
# Format: absolute URL with protocol, no trailing slash. Optional in dev
# (falls back to the production default in lib/site-config.ts).
NEXT_PUBLIC_SITE_URL=https://adwaitmulye.com

# Cross-IDE persistent memory (Mem0 via MCP). Required for the agent workflow,
# not for running the site. Same values across all machines.
MEM0_API_KEY=
MEM0_DEFAULT_USER_ID=

# Primary database connection string. Not used at MVP (no DB until Sprint 2+).
DATABASE_URL=
